  "layout_patterns": {
    "billboard": {
      "name": "封面引流版式",
      "description": "大场景人像/主体全景 + 重点特写叠加",
      "position": "中心/右侧人物大图 + 左侧/顶部超大文字块",
      "elements": ["身份标签", "数据/背书", "利益点", "氛围感滤镜"],
