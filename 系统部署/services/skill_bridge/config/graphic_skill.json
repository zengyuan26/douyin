{
  "_comment": "图文生成 Skill 配置 - 基于选题+画像生成图文内容，包含情绪动线和视觉规范",

  "skill": {
    "name": "graphic_skill",
    "version": "1.0",
    "display_name": "图文内容生成",
    "description": "基于选题、用户画像和关键词库，生成高收录、高权重的图文内容。支持情绪动线规划、视觉规范配置和内容质量控制。",
    "skill_md_path": null,
    "input_source": "from_topic_and_portrait_and_keyword"
  },

  "input_schema": {
    "topic": {
      "type": "object",
      "required": true,
      "description": "选题信息"
    },
    "portrait": {
      "type": "object",
      "description": "目标用户画像"
    },
    "keyword_library": {
      "type": "object",
      "description": "关键词库"
    },
    "business_info": {
      "type": "object",
      "required": true,
      "description": "业务信息"
    },
    "brand_context": {
      "type": "object",
      "description": "品牌上下文（品牌名、信任佐证等）"
    },
    "content_format": {
      "type": "string",
      "default": "种草",
      "description": "内容形式：种草/测评/教程/对比"
    },
    "emotion_curve": {
      "type": "string",
      "description": "情绪曲线：引流→共情→干货→转化"
    },
    "scene_details": {
      "type": "array",
      "description": "场景细分详情"
    }
  },

  "steps": [

    {
      "id": "step_emotion_planning",
      "name": "情绪动线规划",
      "order": 1,
      "required": true,
      "llm_prompt_template": "【情绪动线规划 — 基于选题和画像】\n\n请为以下选题规划情绪动线。\n\n=== 选题信息 ===\n<<topic>>\n\n=== 用户画像 ===\n<<portrait>>\n\n=== 业务信息 ===\n<<business_info>>\n\n=== 情绪曲线参考 ===\n<<emotion_curve>>\n\n请用JSON格式输出：\n\n{\n  \"emotion_curve\": {\n    \"stages\": [\"阶段1\", \"阶段2\", \"阶段3\", \"阶段4\", \"阶段5\"],\n    \"ratios\": [0.2, 0.25, 0.3, 0.15, 0.1],\n    \"keywords\": [\"关键词1\", \"关键词2\"],\n    \"visual_hints\": [\"画面提示1\", \"画面提示2\"]\n  },\n  \"frame_plan\": [\n    {\n      \"frame_index\": 1,\n      \"frame_name\": \"封面引流帧\",\n      \"emotion_target\": \"期待/好奇\",\n      \"content_focus\": \"核心钩子\",\n      \"visual_style\": \"大场景/特写\"\n    }\n  ]\n}",
      "output_field": "emotion_plan",
      "output_schema": {
        "emotion_curve": {
          "type": "object",
          "properties": {
            "stages": {"type": "array", "items": {"type": "string"}},
            "ratios": {"type": "array", "items": {"type": "number"}},
            "keywords": {"type": "array", "items": {"type": "string"}},
            "visual_hints": {"type": "array", "items": {"type": "string"}}
          }
        },
        "frame_plan": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "frame_index": {"type": "integer"},
              "frame_name": {"type": "string"},
              "emotion_target": {"type": "string"},
              "content_focus": {"type": "string"},
              "visual_style": {"type": "string"}
            }
          }
        }
      },
      "data_providers": ["topic", "portrait"]
    },

    {
      "id": "step_slide_design",
      "name": "分镜设计",
      "order": 2,
      "required": true,
      "llm_prompt_template": "【分镜设计 — 基于情绪动线】\n\n请基于情绪动线规划，为以下选题设计详细分镜。\n\n=== 选题信息 ===\n<<topic>>\n\n=== 情绪动线规划 ===\n<<step_emotion_planning>>\n\n=== 用户画像 ===\n<<portrait>>\n\n=== 业务信息 ===\n<<business_info>>\n\n=== 场景细分 ===\n<<scene_details>>\n\n请为每一帧设计详细的画面规范：\n\n{\n  \"slides\": [\n    {\n      \"index\": 1,\n      \"frame_id\": \"封面引流帧\",\n      \"role\": \"封面\",\n      \"emotion_target\": \"期待/好奇\",\n      \"visual_target\": \"视觉目标描述\",\n      \"scene_logic\": \"画面逻辑描述\",\n      \"color_tone\": \"cold/warm/brand\",\n      \"character_description\": \"人物形象描述（全程统一）\",\n      \"light_shadow\": \"光影描述\",\n      \"atmosphere\": \"氛围描述\"\n    }\n  ]\n}",
      "output_field": "slide_design",
      "output_schema": {
        "slides": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object",
            "properties": {
              "index": {"type": "integer"},
              "frame_id": {"type": "string"},
              "role": {"type": "string"},
              "emotion_target": {"type": "string"},
              "visual_target": {"type": "string"},
              "scene_logic": {"type": "string"},
              "color_tone": {"type": "string"},
              "character_description": {"type": "string"},
              "light_shadow": {"type": "string"},
              "atmosphere": {"type": "string"}
            }
          }
        }
      },
      "data_providers": ["step_emotion_planning"]
    },

    {
      "id": "step_content_write",
      "name": "内容撰写",
      "order": 3,
      "required": true,
      "llm_prompt_template": "【内容撰写 — 基于分镜设计】\n\n请基于分镜设计，为每一帧撰写具体的图文内容。\n\n=== 选题信息 ===\n<<topic>>\n\n=== 分镜设计 ===\n<<step_slide_design>>\n\n=== 画像增强信息 ===\n- 语言风格：<<portrait.language_style>>\n- 人群视角：<<portrait.crowd_perspective>>\n- 年龄范围：<<portrait.age_range>>\n- 痛点强度：<<portrait.pain_point_level>>\n- 决策阶段：<<portrait.decision_stage>>\n\n=== 关键词库（参考）===\n<<keyword_library>>\n\n=== 品牌上下文 ===\n<<brand_context>>\n\n请用JSON格式输出完整图文内容：\n\n{\n  \"title\": \"主标题（≤15字）\",\n  \"subtitle\": \"副标题（≤15字）\",\n  \"slides\": [\n    {\n      \"index\": 1,\n      \"frame_id\": \"封面引流帧\",\n      \"main_title\": \"主标题（≤10字）\",\n      \"big_slogan\": \"大字金句（≤15字）\",\n      \"sub_content\": \"副标题/要点\",\n      \"keywords\": [\"埋入关键词\"],\n      \"trust_evidence\": [\n        {\"type\": \"data/case/quote\", \"content\": \"具体内容\", \"source\": \"来源\"}\n      ],\n      \"golden_quote\": {\"text\": \"金句\", \"bg_color\": \"#HEX色值\"}\n    }\n  ],\n  \"hashtags\": [\"#话题1\", \"#话题2\"],\n  \"first_comment\": \"首评引导（≤50字）\",\n  \"cta\": \"行动号召（≤50字）\"\n}",
      "output_field": "content",
      "output_schema": {
        "title": {"type": "string"},
        "subtitle": {"type": "string"},
        "slides": {
          "type": "array",
          "minItems": 5,
          "items": {
            "type": "object",
            "properties": {
              "index": {"type": "integer"},
              "frame_id": {"type": "string"},
              "main_title": {"type": "string"},
              "big_slogan": {"type": "string"},
              "sub_content": {"type": "string"},
              "keywords": {"type": "array", "items": {"type": "string"}},
              "trust_evidence": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "type": {"type": "string"},
                    "content": {"type": "string"},
                    "source": {"type": "string"}
                  }
                }
              },
              "golden_quote": {
                "type": "object",
                "properties": {
                  "text": {"type": "string"},
                  "bg_color": {"type": "string"}
                }
              }
            }
          }
        },
        "hashtags": {"type": "array", "items": {"type": "string"}},
        "first_comment": {"type": "string"},
        "cta": {"type": "string"}
      },
      "data_providers": ["step_slide_design", "portrait"]
    },

    {
      "id": "step_visual_spec",
      "name": "视觉规范输出",
      "order": 4,
      "required": true,
      "llm_prompt_template": "【视觉规范输出 — 统一视觉资产】\n\n请输出完整的视觉规范，确保图文内容在视觉上的一致性。\n\n=== 分镜设计 ===\n<<step_slide_design>>\n\n=== 内容 ===\n<<step_content_write>>\n\n请用JSON格式输出：\n\n{\n  \"color_scheme\": {\n    \"cold_pages\": [\"#冷色调色值\"],\n    \"warm_pages\": [\"#暖色调色值\"],\n    \"brand_pages\": [\"#品牌色色值\"]\n  },\n  \"visual_asset_rules\": {\n    \"character_consistency\": \"人物形象统一描述\",\n    \"light_shadow_logic\": \"光影逻辑描述\",\n    \"anti_examples\": [\"禁止项1\", \"禁止项2\"]\n  },\n  \"production_specs\": {\n    \"image_ratio\": \"9:16\",\n    \"image_size\": \"1080x1920px\",\n    \"text_ratio\": \"≥25%\",\n    \"font_style\": \"字体建议\"\n  }\n}",
      "output_field": "visual_spec",
      "output_schema": {
        "color_scheme": {
          "type": "object",
          "properties": {
            "cold_pages": {"type": "array", "items": {"type": "string"}},
            "warm_pages": {"type": "array", "items": {"type": "string"}},
            "brand_pages": {"type": "array", "items": {"type": "string"}}
          }
        },
        "visual_asset_rules": {
          "type": "object",
          "properties": {
            "character_consistency": {"type": "string"},
            "light_shadow_logic": {"type": "string"},
            "anti_examples": {"type": "array", "items": {"type": "string"}}
          }
        },
        "production_specs": {
          "type": "object",
          "properties": {
            "image_ratio": {"type": "string"},
            "image_size": {"type": "string"},
            "text_ratio": {"type": "string"},
            "font_style": {"type": "string"}
          }
        }
      },
      "data_providers": ["step_slide_design", "step_content_write"]
    }

  ],

  "constraints": {
    "quantity_requirements": {
      "slides_min": 5,
      "slides_max": 9,
      "keywords_per_slide_min": 1,
      "trust_evidence_min": 1
    },
    "quality_rules": {
      "title_required": true,
      "cta_required": true,
      "hashtags_min": 3,
      "hashtags_max": 6
    },
    "content_rules": {
      "title_max_chars": 15,
      "subtitle_max_chars": 15,
      "big_slogan_max_chars": 15,
      "cta_max_chars": 50,
      "first_comment_max_chars": 50,
      "single_page_text_max_chars": 80
    }
  },

  "data_flow": {
    "inputs": {
      "_comment": "graphic_skill 是图文内容生成的核心 Skill",
      "topic": {"source": "topic_library_generator"},
      "portrait": {"source": "portrait_generator"},
      "keyword_library": {"source": "keyword_library_generator"},
      "business_info": {"source": "manual_input"},
      "brand_context": {"source": "manual_input"}
    },
    "outputs": {
      "step_content_write": {
        "_comment": "内容传递给后续审核 Skill",
        "title": {"target": "consumer_psychology", "field": "content.title"},
        "body": {"target": "consumer_psychology", "field": "content.body"},
        "slides": {"target": "visual_design", "field": "slides"},
        "color_scheme": {"target": "visual_design", "field": "content.color_scheme"}
      },
      "step_visual_spec": {
        "_comment": "视觉规范传递给设计工具和视觉审核",
        "color_scheme": {"target": "external", "field": "color_scheme"},
        "visual_asset_rules": {"target": "visual_design", "field": "content.visual_asset_rules"},
        "production_specs": {"target": "external", "field": "production_specs"}
      },
      "step_emotion_planning": {
        "_comment": "情绪规划传递给消费心理学审核",
        "emotion_curve": {"target": "consumer_psychology", "field": "content.emotion_curve"}
      }
    }
  },

  "skill_chain": {
    "_comment": "Skill 调用链配置",
    "after_content_generation": [
      "consumer_psychology",
      "visual_design"
    ],
    "after_review": [
      "content_quality_scorer"
    ]
  }
}
